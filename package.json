{
  "name": "litwave",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:website": "mkdir -p dist/website && cp -r src/website/* dist/website/",
    "deploy:website": "npm run build:website && npx wrangler pages deploy dist/website --project-name=litwave",
    "lint": "ng lint",
    "test": "vitest run",
    "generate:assets": "capacitor-assets generate --iconBackgroundColor '#0f172a' --iconBackgroundColorDark '#0f172a' --splashBackgroundColor '#0f172a' --splashBackgroundColorDark '#0f172a'",
    "sync": "ng build && cap sync",
    "open:ios": "npm run sync && cap open ios",
    "open:android": "npm run sync && cap open android",
    "run:ios": "npm run sync && cap run ios",
    "run:android": "npm run sync && cap run android"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~19.2.0",
    "@angular/core": "~19.2.0",
    "@angular/forms": "~19.2.0",
    "@angular/platform-browser": "~19.2.0",
    "@angular/platform-browser-dynamic": "~19.2.0",
    "@angular/router": "~19.2.0",
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.0",
    "@capawesome/capacitor-torch": "^8.0.0",
    "@ionic/angular": "^8.4.0",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "capacitor-native-settings": "^8.1.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^19.0.0",
    "@angular-devkit/build-angular": "~19.2.0",
    "@angular-eslint/builder": "~19.3.0",
    "@angular-eslint/eslint-plugin": "~19.3.0",
    "@angular-eslint/eslint-plugin-template": "~19.3.0",
    "@angular-eslint/template-parser": "~19.3.0",
    "@angular/cli": "~19.2.0",
    "@angular/compiler": "~19.2.0",
    "@angular/compiler-cli": "~19.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.4"
  },
  "description": "Synchronized crowd lighting app"
}
