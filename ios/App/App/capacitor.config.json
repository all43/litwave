{
	"appId": "app.litwave",
	"appName": "Litwave",
	"webDir": "www",
	"bundledWebRuntime": false,
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 0,
			"launchAutoHide": false,
			"backgroundColor": "#0f172a",
			"androidSplashResourceName": "splash",
			"showSpinner": false
		}
	},
	"packageClassList": [
		"KeepAwakePlugin",
		"AppPlugin",
		"CapacitorBarcodeScannerPlugin",
		"ClipboardPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"LocalNotificationsPlugin",
		"PreferencesPlugin",
		"SharePlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin",
		"TorchPlugin",
		"NativeSettingsPlugin"
	]
}
